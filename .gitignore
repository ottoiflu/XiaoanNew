# 默认忽略所有
*

# 保留目录结构
!*/

# 源代码
!*.py
!*.md

# Git 配置
!.gitignore
!.github/
!.github/**

# Python 缓存
__pycache__/
*.pyc

# 文档
!docs/
!docs/**

# 模型权重
!weights/
!weights/*.pt
*.pt


# 配置文件
!configs/
!*.yaml
!*.yml
!prompts/
!prompts/*.yaml
!*.yml
!config/
!config/*.py

# 项目配置
!requirements.txt
!pyproject.toml
!.env.example

# 环境变量 (敏感信息，不提交)
.env

# 本地环境覆盖文件 (不提交)
.env.local

.gradio/
.ruff_cache/
.vscode/

pytest_cache/
*.egg-info/