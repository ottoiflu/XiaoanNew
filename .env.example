# XiaoanNew 环境变量配置模板
# 支持多环境: development, production, testing
# 使用方式: 复制本文件为 .env 并填入实际值
# cp .env.example .env

# ===== 环境阶段 =====
# 可选值: development, production, testing
ENVIRONMENT=development

# ===== API Keys =====
# VLM 服务 API Key (用于合规性判断)
VLM_API_KEY=your_vlm_api_key_here

# OCR 服务 API Key (用于车牌识别)
OCR_API_KEY=your_ocr_api_key_here

# ===== API 端点 =====
# VLM/OCR 服务基础 URL
API_BASE_URL=https://api.ppinfra.com/openai

# ===== 模型配置 =====
# VLM 模型名称
VLM_MODEL=qwen/qwen3-vl-30b-a3b-instruct

# OCR 模型名称
OCR_MODEL=qwen/qwen3-vl-8b-instruct

# YOLOv8-Seg 模型权重路径
YOLO_WEIGHTS=/root/XiaoanNew/assets/weights/best.pt

# 推理设备 (cuda:0 或 cpu)
INFERENCE_DEVICE=cuda:0

# ===== 服务配置 =====
# Flask 监听端口
FLASK_PORT=5000

# 调试模式 (true/false)
DEBUG_MODE=false

# 最大并发线程数
MAX_WORKERS=15
